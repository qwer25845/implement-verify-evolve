{
  "repo_dir": "/path/to/your/git/checkout",

  "task": "Describe what to implement here, or pass --task / set task_file.",
  "task_file": null,
  "max_iterations": 10,

  "implementer_cmd": ["your-agentic-coding-cli", "--prompt-file", "{prompt_file}"],
  "implementer_env": {},
  "implementer_timeout": 1800,

  "test_cmd": ["pytest", "-q"],
  "test_timeout": 1800,

  "reviewer_cmd": ["hermes", "-z", "{prompt_instruction}"],
  "reviewer_env": { "HERMES_HOME": "/path/to/reviewer/profile" },
  "reviewer_cwd": null,
  "timeout": 600,

  "author_cmd": ["your-author-llm", "--prompt-file", "{prompt_file}"],
  "author_env": {},
  "author_cwd": null,

  "include_patch": true,
  "patch_out_dir": ".",
  "review_targets": [],
  "pr_context": "One paragraph describing what the change does and what the reviewer should focus on.",

  "weights": {
    "CRITICAL": 100,
    "WARNING": 40,
    "SUGGESTION/correctness": 15,
    "SUGGESTION/test": 10,
    "SUGGESTION/docs": 8,
    "SUGGESTION/consistency": 4,
    "SUGGESTION/style": 1
  },
  "unknown_type_weight": 15,
  "stop_cutoff": 5,
  "stop_consecutive": 2,
  "stop_no_escalate_consecutive": 3,
  "escalate_min": 40,

  "log_file": "review-log.md",
  "state_file": ".review_state.json",
  "prompt_file": ".review_prompt.txt",
  "implementer_prompt_file": ".implementer_prompt.txt"
}
